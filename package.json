{
  "name": "quickquill",
  "version": "1.0.0",
  "description": "A clean Markdown editor for macOS",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --mac --dir",
    "dist": "electron-builder --mac"
  },
  "build": {
    "appId": "app.quickquill",
    "productName": "QuickQuill",
    "mac": {
      "category": "public.app-category.productivity",
      "target": [{ "target": "dir", "arch": ["arm64", "x64"] }]
    },
    "files": ["main.js", "preload.js", "renderer/**/*", "node_modules/**/*"]
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  }
}
